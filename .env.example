# ============================================================
# Megaproject — Environment Variables Template
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://megaproject:megaproject_dev@localhost:5432/megaproject
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redpanda / Kafka ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── LLM API Keys ──────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ── LLM Gateway ───────────────────────────────────────────
LLM_GATEWAY_URL=http://localhost:8001
LLM_DEFAULT_MODEL=deepseek/deepseek-chat
LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# ── Object Storage (MinIO / S3) ───────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=megaproject
S3_SECRET_KEY=megaproject_dev
S3_BUCKET_CVS=megaproject-cvs
S3_BUCKET_MATERIALS=megaproject-materials

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Observability ─────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=megaproject
LOG_LEVEL=INFO
